Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[",
  RowBox[{"ChurchE", ",", "S"}], "]"}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"ChurchE", "[", "0", "]"}], "=",
  RowBox[{
   RowBox[{"{",
    RowBox[{"s", ",", "z"}], "}"}], "|->", "z"}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{
   RowBox[{"S", "[",
    RowBox[{"n", ":",
     RowBox[{"_ChurchE", "|", "_Function"}]}], "]"}], ":=",
   RowBox[{
    RowBox[{"{",
     RowBox[{"s", ",", "z"}], "}"}], "|->",
    RowBox[{"n", "[",
     RowBox[{"s", ",",
      RowBox[{"s", "[", "z", "]"}]}], "]"}]}]}],
  RowBox[{"(*",
   RowBox[{"which", " ", "eagerizes", " ", "to"}], "*)"}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"S", "[",
   RowBox[{"n", ":",
    RowBox[{"_ChurchE", "|", "_Function"}]}], "]"}], ":=",
  RowBox[{
   RowBox[{"S", "[", "n", "]"}], "=",
   RowBox[{"Module", "[",
    RowBox[{
     RowBox[{"{",
      RowBox[{"s", ",", "z", ",", "e"}], "}"}], ",", "\[IndentingNewLine]",
     RowBox[{
      RowBox[{
       RowBox[{"{",
        RowBox[{"s", ",", "z"}], "}"}], "=",
       RowBox[{"n", "[",
        RowBox[{"[", "1", "]"}], "]"}]}], ";",
      RowBox[{"e", "=",
       RowBox[{"Evaluate", "[",
        RowBox[{"n", "[",
         RowBox[{"s", ",",
          RowBox[{"s", "[", "z", "]"}]}], "]"}], "]"}]}],
      RowBox[{"(*", " ",
       RowBox[{
        RowBox[{"S", " ", "=", " ",
         RowBox[{"\[Lambda]", " ",
          RowBox[{"n", " ", ".", " ", "\[Lambda]"}], " ", "s"}]}],
        "\[ThinSpace]", "\[InvisibleComma]", "\[ThinSpace]",
        RowBox[{
         RowBox[{"z", " ", ".", " ", "n"}], " ", "s", " ",
         RowBox[{"(",
          RowBox[{
          "s", "\[ThinSpace]", "\[InvisibleApplication]", "\[ThinSpace]",
           "z"}], ")"}]}]}], " ", "*)"}], ";", "\[IndentingNewLine]",
      RowBox[{
       RowBox[{"{",
        RowBox[{
         RowBox[{"{",
          RowBox[{"s", ",", "z"}], "}"}], ",", "e"}], "}"}], "//",
       RowBox[{"Apply", "[", "Function", "]"}]}]}]}], "]"}]}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"ChurchE", "[",
   RowBox[{"n_Integer", "?", "Positive"}], "]"}], ":=",
  RowBox[{
   RowBox[{"ChurchE", "[", "n", "]"}], "=",
   RowBox[{"S", "[",
    RowBox[{"ChurchE", "[",
     RowBox[{"n", "-", "1"}], "]"}], "]"}]}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"churchsimp", "=",
   RowBox[{"(",
    RowBox[{
     RowBox[{"(",
      RowBox[{
       RowBox[{"{",
        RowBox[{
         RowBox[{"#", "[",
          RowBox[{"[", "1", "]"}], "]"}], ",",
         RowBox[{
          RowBox[{"#", "[",
           RowBox[{"[", "2", "]"}], "]"}], "//.",
          RowBox[{"{",
           RowBox[{
            RowBox[{
             RowBox[{"s", "[", "z", "]"}], "->",
             RowBox[{
              TemplateBox[{"Nest"},
               "InactiveHead",
               BaseStyle->"Inactive",
               SyntaxForm->"Symbol",
               Tooltip->"Inactive[Nest]"], "[",
              RowBox[{"s", ",", "z", ",", "1"}], "]"}]}], ",",
            RowBox[{
             RowBox[{"HoldPattern", "[",
              RowBox[{"s", "[",
               RowBox[{
                TemplateBox[{"Nest"},
                 "InactiveHead",
                 BaseStyle->"Inactive",
                 SyntaxForm->"Symbol",
                 Tooltip->"Inactive[Nest]"], "[",
                RowBox[{"s", ",", "e_", ",", "n_"}], "]"}], "]"}], "]"}], ":>",
             RowBox[{
              TemplateBox[{"Nest"},
               "InactiveHead",
               BaseStyle->"Inactive",
               SyntaxForm->"Symbol",
               Tooltip->"Inactive[Nest]"], "[",
              RowBox[{"s", ",", "e", ",",
               RowBox[{"n", "+", "1"}]}], "]"}]}]}], "}"}]}]}], "}"}], "//",
       RowBox[{"Apply", "[", "Function", "]"}]}], ")"}], "&"}], ")"}]}],
  ";"}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"ChurchE", "[", "3", "]"}], "//", "churchsimp"}]}], "Input"]
}]],


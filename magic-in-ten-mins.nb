Cell[BoxData[{
 RowBox[{
  RowBox[{"ShopList", "[", "prices_Association", "]"}], ":=", 
  RowBox[{"ShopList", "[", 
   RowBox[{
    RowBox[{"<|", "|>"}], ",", "prices"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ShopList", "[", 
     RowBox[{"counts_Association", ",", "prices_Association"}], "]"}], 
    "[", "\"\<buy\>\"", "]"}], "[", "name_", "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"newcounts", "=", 
      RowBox[{"Merge", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"counts", ",", "\[IndentingNewLine]", 
          RowBox[{"<|", 
           RowBox[{"name", "->", 
            RowBox[{"Boole", "@", 
             RowBox[{"KeyMemberQ", "[", 
              RowBox[{"prices", ",", "name"}], "]"}]}]}], "|>"}]}], "}"}], ",",
         "Total"}], "]"}]}], "}"}], ",", 
    RowBox[{"ShopList", "[", 
     RowBox[{"newcounts", ",", "prices"}], "]"}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[410]:=",ExpressionUUID->"01a3f048-1894-734d-9676-ae42df938c30"],

Cell[CellGroupData[{

Cell["pretty printing", "Item",ExpressionUUID->"2ca00373-bfa4-6641-97b9-f5ba0315a7d7"],

Cell[BoxData[
 RowBox[{"ShopList", "/:", 
  RowBox[{"Format", "[", 
   RowBox[{
    RowBox[{"sl", ":", 
     RowBox[{"ShopList", "[", 
      RowBox[{"counts_Association", ",", "prices_Association"}], "]"}]}], ",",
     "StandardForm"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"row", "=", "BoxForm`MakeSummaryItem"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"cartitems", "=", 
       RowBox[{"Keys", "[", "counts", "]"}]}], ",", 
      RowBox[{"allitems", "=", 
       RowBox[{"Keys", "[", "prices", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"totalCount", "=", 
       RowBox[{"Total", "[", "counts", "]"}]}], ",", 
      RowBox[{"totalPrice", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"KeyValueMap", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"prices", "[", "#1", "]"}], "*", "#2"}], "&"}], ",", 
          "counts"}], "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"selected", "=", 
       RowBox[{"KeyTake", "[", 
        RowBox[{"prices", ",", 
         RowBox[{"Keys", "[", "counts", "]"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"unselected", "=", 
       RowBox[{"KeyDrop", "[", 
        RowBox[{"prices", ",", 
         RowBox[{"Keys", "[", "counts", "]"}]}], "]"}]}]}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"RawBoxes", "@", 

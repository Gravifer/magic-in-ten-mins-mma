          RowBox[{"HoldForm", "[", "expr", "]"}]}], "}"}]}], "}"}], "}"}], ",",
     RowBox[{"{", "}"}], ",", "StandardForm"}], "]"}]}]}], "\[IndentingNewLine]",
 RowBox[{"SetAttributes", "[",
  RowBox[{"fv", ",",
   RowBox[{"{", "HoldAll", "}"}]}], "]"}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"fv", "[", "x_Symbol", "]"}], ":=",
  RowBox[{"{", "x", "}"}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{"fv", "[",
   RowBox[{"f_lambda", "[", "e_", "]"}], "]"}], ":=",
  RowBox[{"Union", "[",
   RowBox[{
    RowBox[{"fv", "[", "f", "]"}], ",",
    RowBox[{"fv", "[", "e", "]"}]}], "]"}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{
   RowBox[{"fv", "[",
    RowBox[{"lambda", "[",
     RowBox[{"x_Symbol", ",", "m_"}], "]"}], "]"}], ":=",
   RowBox[{"Complement", "[",
    RowBox[{
     RowBox[{"fv", "[", "m", "]"}], ",",
     RowBox[{"fv", "[", "x", "]"}]}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{
   RowBox[{"subst", "[", "x_Symbol", "]"}], "[",
   RowBox[{"y_Symbol", ",", "n_"}], "]"}], ":=",
  RowBox[{"x", "/.",
   RowBox[{"y", "->", "n"}]}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{
   RowBox[{"subst", "[",
    RowBox[{"f_", "[", "e_", "]"}], "]"}], "[",
   RowBox[{"y_Symbol", ",", "n_"}], "]"}], ":=",
  RowBox[{
   RowBox[{
    RowBox[{"subst", "[", "f", "]"}], "[",
    RowBox[{"y", ",", "n"}], "]"}], "@",

     "\[IndentingNewLine]", 
     RowBox[{"body", "[", "cont", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"cs", "=", 
      RowBox[{"Rest", "[", "cs", "]"}]}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{

 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"list", "=", 
      RowBox[{"ShopList", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<water\>\"", "->", 
          TemplateBox[{"1", 
            RowBox[{
              FormBox["\"$\"", TraditionalForm], "\[VeryThinSpace]"}], 
            "US dollars", "\"USDollars\""},
           "QuantityPrefix"]}], ",", 
         RowBox[{"\"\<cola\>\"", "->", 
          TemplateBox[{"2", 
            RowBox[{
              FormBox["\"$\"", TraditionalForm], "\[VeryThinSpace]"}], 
            "US dollars", "\"USDollars\""},
           "QuantityPrefix"]}], ",", 
         RowBox[{"\"\<choco\>\"", "->", 
          TemplateBox[{"5", 
            RowBox[{
              FormBox["\"$\"", TraditionalForm], "\[VeryThinSpace]"}], 
            "US dollars", "\"USDollars\""},
           "QuantityPrefix"]}]}], "|>"}], "]"}]}], ",", "\[IndentingNewLine]",
      "events", ",", 
     RowBox[{"indices", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}]}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"events", "=", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"list", "=", 

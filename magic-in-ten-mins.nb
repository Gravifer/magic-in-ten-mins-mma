   RowBox[{"y_Symbol", ",", "n_"}], "]"}], ":=",
  RowBox[{
   RowBox[{"lambda", "[",
    RowBox[{"y", ",", "m"}], "]"}], "/;",
   RowBox[{"SameQ", "[",
    RowBox[{"x", ",", "y"}], "]"}]}]}], "\[IndentingNewLine]",
 RowBox[{
  RowBox[{
   RowBox[{"subst", "[",
    RowBox[{"lambda", "[",
     RowBox[{"x_Symbol", ",", "m_"}], "]"}], "]"}], "[",
   RowBox[{"y_Symbol", ",", "n_"}], "]"}], ":=",
  RowBox[{
   RowBox[{"lambda", "[",
    RowBox[{"x", ",",

            RowBox[{"Boole", "@",
             RowBox[{"KeyMemberQ", "[",
              RowBox[{"prices", ",", "name"}], "]"}]}]}], "|>"}]}], "}"}], ",",
         "Total"}], "]"}]}], "}"}], ",",
    RowBox[{"ShopList", "[",
     RowBox[{"newcounts", ",", "prices"}], "]"}]}], "]"}]}]}], "Input"],

Cell[CellGroupData[{

Cell["pretty printing", "Item"],

Cell[BoxData[
 RowBox[{"ShopList", "/:",
  RowBox[{"Format", "[",
   RowBox[{
    RowBox[{"sl", ":",
     RowBox[{"ShopList", "[",
      RowBox[{"counts_Association", ",", "prices_Association"}], "]"}]}], ",",
     "StandardForm"}], "]"}], ":=",
  RowBox[{"Module", "[",
   RowBox[{
    RowBox[{"{",
     RowBox[{
      RowBox[{"row", "=", "BoxForm`MakeSummaryItem"}], ",",
      "\[IndentingNewLine]",
      RowBox[{"cartitems", "=",
       RowBox[{"Keys", "[", "counts", "]"}]}], ",",
      RowBox[{"allitems", "=",
       RowBox[{"Keys", "[", "prices", "]"}]}], ",", "\[IndentingNewLine]",
      RowBox[{"totalCount", "=",
       RowBox[{"Total", "[", "counts", "]"}]}], ",",
      RowBox[{"totalPrice", "=",
       RowBox[{"Total", "[",
        RowBox[{"KeyValueMap", "[",
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"prices", "[", "#1", "]"}], "*", "#2"}], "&"}], ",",
          "counts"}], "]"}], "]"}]}], ",", "\[IndentingNewLine]",
      RowBox[{"selected", "=",
       RowBox[{"KeyTake", "[",
        RowBox[{"prices", ",",
         RowBox[{"Keys", "[", "counts", "]"}]}], "]"}]}], ",",
      "\[IndentingNewLine]",
      RowBox[{"unselected", "=",
       RowBox[{"KeyDrop", "[",
        RowBox[{"prices", ",",
         RowBox[{"Keys", "[", "counts", "]"}]}], "]"}]}]}],
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]",
    RowBox[{"RawBoxes", "@",
     RowBox[{"BoxForm`ArrangeSummaryBox", "[",
      RowBox[{"ShopList", ",", "sl", ",",
       GraphicsBox[
        TagBox[RasterBox[CompressedData["

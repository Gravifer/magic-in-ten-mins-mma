 RowBox[{"ClearAll", "[",
  RowBox[{"lambda", ",", "fv", ",", "subst"}], "]"}], "\[IndentingNewLine]",
 RowBox[{"SetAttributes", "[",
  RowBox[{"lambda", ",",

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "test", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"test", "[", "t_", "]"}], ":=", 
  RowBox[{"try", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cont", "|->", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", "\"\<try\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"t", "==", "0"}], ",", 
         RowBox[{"throw", "[", 
          InterpretationBox[
           DynamicModuleBox[{Typeset`open = False}, 
            TemplateBox[{"Expression", 
              RowBox[{"Failure", "[", 
                DynamicBox[
                 FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], 
                "]"}], 
              GridBox[{{
                 RowBox[{
                   TagBox["\"Byte count: \"", "IconizedLabel"], 
                   "\[InvisibleSpace]", 
                   TagBox["696", "IconizedItem"]}]}}, 
               GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
               "Column", 
               GridBoxItemSize -> {
                "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
              Dynamic[Typeset`open]},
             "IconizedObject"]],
           Failure[
           "DivisionByZero", <|
            "MessageTemplate" -> MessageName[Divide, "infy"], 
             "MessageParameters" -> {
               HoldForm[1/0]}|>],
           SelectWithContents->True,
           Selectable->False], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"100", "/", "t"}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"cont", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", ")"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"e", ",", "cont"}], "}"}], "|->", 
     RowBox[{"(", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", "\"\<catch\>\"", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"cont", "[", "]"}]}], "\[IndentingNewLine]", ")"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Print", "[", "\"\<final\>\"", "]"}], "&"}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellLabel->
  "In[436]:=",ExpressionUUID->"8c090faa-f638-204a-8ce6-ad0011157906"],


Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cs", "=", 
    RowBox[{"{", "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"Stack", " ", "of", " ", "handlers"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"try", "[", 
